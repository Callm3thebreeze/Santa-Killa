---
import Header from "@components/Header.astro";
import Hero from "@components/Hero.astro";
import IntroSection from "@components/IntroSection.astro";
import PricingSection from "@components/PricingSection.astro";
import ScheduleSection from "@components/ScheduleSection.astro";
import SeoContentSection from "@components/SeoContentSection.astro";
import ContactSection from "@components/ContactSection.astro";
import FaqSection from "@components/FaqSection.astro";
import Footer from "@components/Footer.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { contact } from "@data/contact";
import { faqs } from "@data/faqs";
import { pricing } from "@data/pricing";

const title = "Santa Killa | Escuela de surf en El Palmar, Cádiz";
const description =
  "Escuela de surf en El Palmar, Cádiz. Clases de surf para todos los niveles en un entorno seguro, cercano y junto al Atlántico.";
const siteUrl = Astro.site ?? new URL("https://www.santakilla.com");
const homeUrl = new URL("/", siteUrl).toString();
const businessId = `${homeUrl}#business`;
const websiteId = `${homeUrl}#website`;
const webpageId = `${homeUrl}#webpage`;
const imageUrl = new URL("/images/hero-poster.svg", siteUrl).toString();

const businessSchema = {
  "@context": "https://schema.org",
  "@type": "SportsActivityLocation",
  "@id": businessId,
  name: "Santa Killa",
  url: homeUrl,
  logo: new URL("/images/white-logo.png", siteUrl).toString(),
  image: imageUrl,
  description,
  telephone: contact.phone,
  email: contact.email,
  hasMap: contact.mapsExternalUrl,
  priceRange: "30 EUR - 140 EUR",
  inLanguage: "es-ES",
  address: {
    "@type": "PostalAddress",
    streetAddress: "P.º Marítimo",
    postalCode: "11159",
    addressLocality: "El Palmar de Vejer",
    addressRegion: "Cádiz",
    addressCountry: "ES",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: contact.latitude,
    longitude: contact.longitude,
  },
  areaServed: ["El Palmar", "Cádiz", "Costa de la Luz"],
  openingHours: ["Mo-Fr 09:00-19:00", "Sa 09:00-14:00"],
  sameAs: [contact.mapsExternalUrl],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Clases de surf Santa Killa",
    itemListElement: pricing.map((item) => ({
      "@type": "Offer",
      name: item.title,
      description: item.description,
      price: item.price.replace(/[^0-9]/g, ""),
      priceCurrency: "EUR",
      availability: "https://schema.org/InStock",
      itemOffered: {
        "@type": "Service",
        name: item.title,
        serviceType: "Clases de surf en El Palmar",
        areaServed: "El Palmar, Cádiz",
      },
    })),
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": websiteId,
  name: "Santa Killa",
  url: homeUrl,
  inLanguage: "es-ES",
  publisher: {
    "@id": businessId,
  },
};

const webpageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": webpageId,
  url: homeUrl,
  name: title,
  description,
  inLanguage: "es-ES",
  isPartOf: {
    "@id": websiteId,
  },
  about: {
    "@id": businessId,
  },
  primaryImageOfPage: {
    "@type": "ImageObject",
    url: imageUrl,
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Santa Killa",
      item: homeUrl,
    },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[
    businessSchema,
    websiteSchema,
    webpageSchema,
    breadcrumbSchema,
    faqSchema,
  ]}
>
  <Header />
  <main id="main-content">
    <Hero />
    <IntroSection />
    <PricingSection />
    <ScheduleSection />
    <SeoContentSection />
    <ContactSection />
    <FaqSection />
  </main>
  <Footer />
</BaseLayout>
