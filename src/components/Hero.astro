---
import { contact } from "@data/contact";
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__media" aria-hidden="true">
    <img
      class="hero__poster"
      src="/images/hero-poster.svg"
      alt=""
      width="1920"
      height="1080"
    />
    <video
      class="hero__video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/images/hero-poster.svg"
      tabindex="-1"
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
      <source src="/videos/hero.mov" type="video/quicktime" />
    </video>
  </div>

  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="hero__content container" data-reveal>
    <img
      class="hero__logo"
      src="/images/logo-santa-killa.svg"
      alt="Santa Killa"
      width="260"
      height="120"
      loading="eager"
      decoding="async"
    />
    <p class="hero__eyebrow">Santa Killa Surf School</p>
    <h1 id="hero-title">Escuela de surf en El Palmar, Cádiz</h1>
    <p class="hero__text">
      Clases de surf para todos los niveles en una escuela cercana, segura y
      conectada con el Atlántico.
    </p>
    <div class="hero__actions" aria-label="Acciones principales">
      <a class="button-link" href="#tarifas">Ver tarifas</a>
      <a
        class="hero__secondary"
        href={contact.whatsapp}
        target="_blank"
        rel="noreferrer">Contactar</a
      >
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 100vh;
    min-height: 100svh;
    overflow: hidden;
    color: var(--color-white);
    background: var(--color-black);
  }

  .hero__media,
  .hero__overlay,
  .hero__video,
  .hero__poster {
    position: absolute;
    inset: 0;
  }

  .hero__video,
  .hero__poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__video {
    z-index: 1;
    filter: brightness(0.48) saturate(0.82) contrast(1.02);
    transform: scale(1.015);
  }

  .hero__poster {
    z-index: 0;
  }

  .hero__overlay {
    z-index: 2;
    background:
      linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.72),
        rgba(0, 0, 0, 0.48) 44%,
        rgba(0, 0, 0, 0.78)
      ),
      radial-gradient(
        circle at 50% 46%,
        rgba(255, 255, 255, 0.08),
        transparent 42%
      );
  }

  .hero__content {
    position: relative;
    z-index: 3;
    display: grid;
    justify-items: center;
    max-width: 820px;
    padding-top: 78px;
    text-align: center;
  }

  .hero__logo {
    width: clamp(170px, 22vw, 260px);
    height: auto;
    margin-bottom: clamp(28px, 5vw, 48px);
  }

  .hero__eyebrow {
    margin-bottom: 16px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    font-family: var(--font-display);
    font-size: clamp(3.3rem, 10vw, 8.6rem);
    font-weight: 640;
    letter-spacing: 0;
    line-height: 0.88;
    text-wrap: balance;
  }

  .hero__text {
    max-width: 610px;
    margin-top: 26px;
    color: rgba(255, 255, 255, 0.86);
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    line-height: 1.75;
    text-wrap: pretty;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 18px;
    margin-top: 36px;
  }

  .hero__secondary {
    display: inline-flex;
    align-items: center;
    min-height: 48px;
    color: var(--color-white);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .hero__secondary::after {
    content: "";
    width: 34px;
    height: 1px;
    margin-left: 12px;
    background: currentColor;
    transition: width 180ms var(--ease-out);
  }

  .hero__secondary:hover::after {
    width: 48px;
  }

  @media (max-width: 640px) {
    .hero__content {
      padding-top: 68px;
    }

    .hero__logo {
      width: clamp(140px, 42vw, 190px);
      margin-bottom: 26px;
    }

    .hero__eyebrow {
      margin-bottom: 12px;
      font-size: 0.68rem;
    }

    h1 {
      font-size: clamp(2.8rem, 15vw, 4.6rem);
      line-height: 0.92;
    }

    .hero__text {
      margin-top: 22px;
    }

    .hero__actions {
      width: 100%;
      gap: 14px;
      margin-top: 30px;
    }

    .hero__actions a {
      width: min(100%, 260px);
    }
  }
</style>
