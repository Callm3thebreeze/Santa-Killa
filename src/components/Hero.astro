---
import { Image } from "astro:assets";
import { contact } from "@data/contact";
import hero1 from "../assets/hero1.webp";
import hero2 from "../assets/hero-2.webp";
import hero4 from "../assets/hero-4.webp";
import hero5 from "../assets/hero-5.webp";

const heroImages = [hero2, hero4, hero1, hero5];
---

<section class="hero" aria-label="Presentación de Santa Killa">
  <div class="hero__media" data-hero-carousel aria-hidden="true">
    {
      heroImages.map((image, index) => (
        <Image
          class:list={["hero__slide", { "is-active": index === 0 }]}
          src={image}
          alt=""
          widths={[640, 960, 1280, 1920]}
          sizes="100vw"
          loading={index === 0 ? "eager" : "lazy"}
          fetchpriority={index === 0 ? "high" : "auto"}
          data-hero-slide
        />
      ))
    }
  </div>

  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="hero__content container" data-reveal>
    <img
      class="hero__logo"
      src="/images/SCHOOL.png"
      alt="Santa Killa"
      width="520"
      height="240"
      loading="eager"
      decoding="async"
    />

    <p class="hero__text">
      Clases de surf para todos los niveles en una escuela cercana, segura y
      conectada con el Atlántico.
    </p>
    <div class="hero__actions" aria-label="Acciones principales">
      <a class="hero__secondary" href="#tarifas">Ver tarifas</a>
      <a
        class="button-link"
        href={contact.whatsapp}
        target="_blank"
        rel="noreferrer">Contactar</a
      >
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const carousel = document.querySelector("[data-hero-carousel]");
    if (!(carousel instanceof HTMLElement)) {
      return;
    }

    const slides = [...carousel.querySelectorAll("[data-hero-slide]")];
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let currentSlide = 0;
    let intervalId;

    const stopCarousel = () => window.clearInterval(intervalId);
    const startCarousel = () => {
      stopCarousel();
      if (reduceMotion.matches || document.hidden || slides.length < 2) return;

      intervalId = window.setInterval(() => {
        slides[currentSlide].classList.remove("is-active");
        currentSlide = (currentSlide + 1) % slides.length;
        slides[currentSlide].classList.add("is-active");
      }, 5500);
    };

    document.addEventListener("visibilitychange", startCarousel);
    reduceMotion.addEventListener("change", startCarousel);
    startCarousel();
  })();
</script>

<style>
  .hero {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 100vh;
    min-height: 100svh;
    overflow: hidden;
    color: var(--color-white);
    background: var(--color-black);
  }

  .hero__media,
  .hero__overlay,
  .hero__slide {
    position: absolute;
    inset: 0;
  }

  .hero__media {
    background: var(--color-black);
  }

  .hero__slide {
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    opacity: 0;
    filter: brightness(0.42) saturate(0.82) contrast(1.04);
    transform: scale(1.025);
    transition:
      opacity 1200ms ease-in-out,
      transform 6500ms linear;
  }

  .hero__slide.is-active {
    opacity: 1;
    transform: scale(1.01);
  }

  .hero__overlay {
    z-index: 2;
  }

  .hero__content {
    position: relative;
    z-index: 3;
    display: grid;
    justify-items: center;
    max-width: 820px;
    padding-top: 78px;
    padding-bottom: 78px;
    text-align: center;
  }

  .hero__logo {
    width: clamp(340px, 44vw, 520px);
    height: auto;
    margin-bottom: clamp(18px, 3vw, 24px);
  }

  .hero__eyebrow {
    margin-bottom: 12px;
    font-family: var(--font-accent);
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .hero__text {
    max-width: 610px;
    margin-top: 8px;
    color: rgba(255, 255, 255, 0.86);
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    line-height: 1.75;
    text-wrap: pretty;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 18px;
    margin-top: 36px;
  }

  .hero__secondary {
    display: inline-flex;
    align-items: center;
    position: relative;
    min-height: 48px;
    color: var(--color-white);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-decoration: none;
    text-transform: uppercase;
  }

  .hero__secondary::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 6px;
    background:
      linear-gradient(
          -45deg,
          transparent 44%,
          currentColor 45% 55%,
          transparent 56%
        )
        0 0 / 10px 6px repeat-x,
      linear-gradient(
          45deg,
          transparent 44%,
          currentColor 45% 55%,
          transparent 56%
        )
        5px 0 / 10px 6px repeat-x;
    opacity: 0.86;
    transition:
      opacity 180ms var(--ease-out),
      transform 180ms var(--ease-out);
  }

  .hero__secondary:hover::after {
    opacity: 1;
    transform: translateY(-3px);
  }

  @media (max-width: 640px) {
    .hero__content {
      padding-top: 68px;
      padding-bottom: 68px;
    }

    .hero__logo {
      width: clamp(280px, 84vw, 380px);
      margin-bottom: 18px;
    }

    .hero__eyebrow {
      margin-bottom: 10px;
      font-size: 0.66rem;
    }

    .hero__text {
      margin-top: 22px;
    }

    .hero__actions {
      width: 100%;
      gap: 14px;
      margin-top: 30px;
    }

    .hero__actions a {
      width: min(100%, 260px);
    }

    .hero__actions .hero__secondary {
      width: fit-content;
      min-height: 48px;
      margin-inline: auto;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__slide {
      transition: none;
      transform: none;
    }
  }
</style>
