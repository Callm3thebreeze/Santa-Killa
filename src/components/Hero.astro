---
import { contact } from "@data/contact";
---

<section class="hero" aria-label="Presentación de Santa Killa">
  <div class="hero__media" aria-hidden="true">
    <video
      class="hero__video"
      autoplay
      muted
      loop
      playsinline
      disableRemotePlayback
      disablepictureinpicture
      preload="metadata"
      poster="/images/hero-poster.svg"
      tabindex="-1"
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
  </div>

  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="hero__content container" data-reveal>
    <img
      class="hero__logo"
      src="/images/SCHOOL.png"
      alt="Santa Killa"
      width="520"
      height="240"
      loading="eager"
      decoding="async"
    />

    <p class="hero__text">
      Clases de surf para todos los niveles en una escuela cercana, segura y
      conectada con el Atlántico.
    </p>
    <div class="hero__actions" aria-label="Acciones principales">
      <a class="hero__secondary" href="#tarifas">Ver tarifas</a>
      <a
        class="button-link"
        href={contact.whatsapp}
        target="_blank"
        rel="noreferrer">Contactar</a
      >
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const heroVideo = document.querySelector(".hero__video");
    if (!(heroVideo instanceof HTMLVideoElement)) {
      return;
    }

    const tryPlay = () => {
      heroVideo.muted = true;
      heroVideo.defaultMuted = true;
      heroVideo.playsInline = true;

      const promise = heroVideo.play();
      if (promise && typeof promise.catch === "function") {
        promise.catch(() => {
          // Algunos navegadores bloquean autoplay hasta interacción.
        });
      }
    };

    if (heroVideo.readyState >= 2) {
      tryPlay();
    } else {
      heroVideo.addEventListener("canplay", tryPlay, { once: true });
    }

    window.addEventListener("pageshow", () => {
      if (heroVideo.paused) {
        tryPlay();
      }
    });

    document.addEventListener("visibilitychange", () => {
      if (!document.hidden && heroVideo.paused) {
        tryPlay();
      }
    });

    const resumeOnInteraction = () => {
      if (heroVideo.paused) {
        tryPlay();
      }
    };

    window.addEventListener("pointerdown", resumeOnInteraction, {
      once: true,
      passive: true,
    });
    window.addEventListener("touchstart", resumeOnInteraction, {
      once: true,
      passive: true,
    });
    window.addEventListener("keydown", resumeOnInteraction, { once: true });
  })();
</script>

<style>
  .hero {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 100vh;
    min-height: 100svh;
    overflow: hidden;
    color: var(--color-white);
    background: var(--color-black);
  }

  .hero__media,
  .hero__overlay,
  .hero__video {
    position: absolute;
    inset: 0;
  }

  .hero__media {
    background: #cfd3d1;
  }

  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__video {
    z-index: 1;
    filter: brightness(0.48) saturate(0.82) contrast(1.02);
    transform: scale(1.015);
  }

  .hero__overlay {
    z-index: 2;
  }

  .hero__content {
    position: relative;
    z-index: 3;
    display: grid;
    justify-items: center;
    max-width: 820px;
    padding-top: 78px;
    padding-bottom: 78px;
    text-align: center;
  }

  .hero__logo {
    width: clamp(340px, 44vw, 520px);
    height: auto;
    margin-bottom: clamp(18px, 3vw, 24px);
  }

  .hero__eyebrow {
    margin-bottom: 12px;
    font-family: var(--font-accent);
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .hero__text {
    max-width: 610px;
    margin-top: 8px;
    color: rgba(255, 255, 255, 0.86);
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    line-height: 1.75;
    text-wrap: pretty;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 18px;
    margin-top: 36px;
  }

  .hero__secondary {
    display: inline-flex;
    align-items: center;
    position: relative;
    min-height: 48px;
    color: var(--color-white);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-decoration: none;
    text-transform: uppercase;
  }

  .hero__secondary::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 6px;
    background:
      linear-gradient(
          -45deg,
          transparent 44%,
          currentColor 45% 55%,
          transparent 56%
        )
        0 0 / 10px 6px repeat-x,
      linear-gradient(
          45deg,
          transparent 44%,
          currentColor 45% 55%,
          transparent 56%
        )
        5px 0 / 10px 6px repeat-x;
    opacity: 0.86;
    transition:
      opacity 180ms var(--ease-out),
      transform 180ms var(--ease-out);
  }

  .hero__secondary:hover::after {
    opacity: 1;
    transform: translateY(-3px);
  }

  @media (max-width: 640px) {
    .hero__content {
      padding-top: 68px;
      padding-bottom: 68px;
    }

    .hero__logo {
      width: clamp(280px, 84vw, 380px);
      margin-bottom: 18px;
    }

    .hero__eyebrow {
      margin-bottom: 10px;
      font-size: 0.66rem;
    }

    .hero__text {
      margin-top: 22px;
    }

    .hero__actions {
      width: 100%;
      gap: 14px;
      margin-top: 30px;
    }

    .hero__actions a {
      width: min(100%, 260px);
    }

    .hero__actions .hero__secondary {
      width: fit-content;
      min-height: 48px;
      margin-inline: auto;
      justify-content: center;
    }
  }
</style>
