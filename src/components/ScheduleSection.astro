---
import SectionHeading from "./SectionHeading.astro";
import { schedule } from "@data/schedule";
import schoolOneImage from "../assets/school1.png";
import schoolTwoImage from "../assets/shool2.png";

const scheduleGallery = [
  {
    image: schoolOneImage,
    alt: "Clase de surf de Santa Killa en la playa de El Palmar",
  },
  {
    image: schoolTwoImage,
    alt: "Grupo de alumnos de Santa Killa junto al mar",
  },
];
---

<section id="horario" class="schedule section">
  <div class="schedule__inner container">
    <div>
      <SectionHeading
        eyebrow=""
        title="Horarios"
        intro="Las condiciones del mar cambian cada día.
Por eso organizamos las clases según la previsión y disponibilidad, para ofrecer la mejor experiencia posible en el agua."
      />
    </div>

    <div class="schedule__panel" data-reveal>
      <h3>Atención y reservas</h3>
      <dl>
        {
          schedule.map((item) => (
            <div class="schedule__row">
              <dt>{item.day}</dt>
              <dd>{item.hours}</dd>
            </div>
          ))
        }
      </dl>
      <p>
        Si vienes a El Palmar varios días, podemos ayudarte a elegir el mejor
        momento para aprender surf según la previsión.
      </p>
    </div>
  </div>

  <div
    class="schedule__gallery-wrap"
    aria-label="Fotos de Santa Killa y sesiones de surf"
    data-reveal
  >
    <div class="schedule__gallery" role="list">
      {
        scheduleGallery.map((item) => (
          <figure class="schedule__photo" role="listitem">
            <img
              src={item.image.src}
              alt={item.alt}
              width={item.image.width}
              height={item.image.height}
              loading="lazy"
              decoding="async"
            />
          </figure>
        ))
      }
    </div>
    <div class="schedule__dots" aria-hidden="true">
      {scheduleGallery.map(() => <span></span>)}
    </div>
  </div>
</section>

<style>
  .schedule__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.68fr);
    gap: clamp(42px, 7vw, 96px);
    align-items: start;
  }

  .schedule__panel {
    padding: clamp(24px, 4vw, 42px);
    background: var(--color-black);
    border-radius: var(--radius-card);
    color: var(--color-white);
  }

  h3 {
    margin-bottom: 30px;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 3rem);
    font-weight: 640;
    letter-spacing: var(--tracking-display);
    line-height: 0.98;
  }

  dl {
    display: grid;
  }

  .schedule__row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 20px;
    padding-block: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }

  .schedule__row:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  dt {
    font-weight: 750;
  }

  dd {
    margin: 0;
    color: rgba(255, 255, 255, 0.78);
    text-align: right;
  }

  .schedule__panel p {
    margin-top: 28px;
    color: rgba(255, 255, 255, 0.74);
    line-height: 1.75;
  }

  .schedule__gallery-wrap {
    position: relative;
    width: 100vw;
    margin-top: clamp(40px, 6vw, 76px);
    margin-left: calc(50% - 50vw);
  }

  .schedule__gallery {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 50vw;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: thin;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
  }

  .schedule__photo {
    margin: 0;
    overflow: hidden;
    background: var(--color-gray-100);
    scroll-snap-align: start;
  }

  .schedule__photo img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .schedule__dots {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 18px;
    display: flex;
    justify-content: center;
    gap: 9px;
    pointer-events: none;
  }

  .schedule__dots span {
    width: 7px;
    height: 7px;
    background: var(--color-white);
    border-radius: 999px;
    opacity: 0.62;
  }

  .schedule__dots span:first-child {
    opacity: 0.92;
  }

  @media (max-width: 880px) {
    .schedule__inner {
      grid-template-columns: 1fr;
    }

    .schedule__gallery {
      grid-auto-columns: 82vw;
    }
  }

  @media (max-width: 520px) {
    .schedule__row {
      grid-template-columns: 1fr;
      gap: 6px;
    }

    dd {
      text-align: left;
    }

    .schedule__gallery {
      grid-auto-columns: 100%;
    }
  }
</style>
