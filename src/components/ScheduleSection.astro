---
import SectionHeading from "./SectionHeading.astro";
import { schedule } from "@data/schedule";
import schoolOneImage from "../assets/school1.png";
import schoolTwoImage from "../assets/shool2.png";
import heroThreeImage from "../assets/hero-3.webp";
import heroFourImage from "../assets/hero-4.webp";

const scheduleGallery = [
  {
    image: schoolOneImage,
    alt: "Clase de surf de Santa Killa en la playa de El Palmar",
  },
  {
    image: schoolTwoImage,
    alt: "Grupo de alumnos de Santa Killa junto al mar",
  },
  {
    image: heroThreeImage,
    alt: "Sesión de surf de Santa Killa en El Palmar",
  },
  {
    image: heroFourImage,
    alt: "Surf en las olas de El Palmar con Santa Killa",
  },
];
---

<section id="horario" class="schedule section">
  <div class="schedule__inner container">
    <div>
      <SectionHeading
        eyebrow=""
        title="Horarios"
        intro="Las condiciones del mar cambian cada día.
Por eso organizamos las clases según la previsión y disponibilidad, para ofrecer la mejor experiencia posible en el agua."
      />
    </div>

    <div class="schedule__panel" data-reveal>
      <h3>Atención y reservas</h3>
      <dl>
        {
          schedule.map((item) => (
            <div class="schedule__row">
              <dt>{item.day}</dt>
              <dd>{item.hours}</dd>
            </div>
          ))
        }
      </dl>
      <p>
        Si vienes a El Palmar varios días, podemos ayudarte a elegir el mejor
        momento para aprender surf según la previsión.
      </p>
    </div>
  </div>

  <div
    class="schedule__gallery-wrap"
    aria-label="Fotos de Santa Killa y sesiones de surf"
    data-reveal
  >
    <div class="schedule__gallery" role="list" data-schedule-gallery>
      {
        scheduleGallery.map((item, index) => (
          <figure
            class="schedule__photo"
            role="listitem"
            data-schedule-photo
            data-index={index}
          >
            <img
              src={item.image.src}
              alt={item.alt}
              width={item.image.width}
              height={item.image.height}
              loading="lazy"
              decoding="async"
            />
          </figure>
        ))
      }
    </div>
    <div class="schedule__dots" aria-label="Seleccionar foto del carrusel">
      {
        scheduleGallery.map((_, index) => (
          <button
            class:list={["schedule__dot", { "is-active": index === 0 }]}
            type="button"
            aria-label={`Ver foto ${index + 1} de ${scheduleGallery.length}`}
            aria-current={index === 0 ? "true" : undefined}
            data-schedule-dot
            data-index={index}
          />
        ))
      }
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const gallery = document.querySelector("[data-schedule-gallery]");
    if (!(gallery instanceof HTMLElement)) return;

    const photos = [...gallery.querySelectorAll("[data-schedule-photo]")];
    const dots = [...document.querySelectorAll("[data-schedule-dot]")];

    const setActiveDot = (activeIndex) => {
      dots.forEach((dot, index) => {
        const isActive = index === activeIndex;
        dot.classList.toggle("is-active", isActive);
        if (isActive) dot.setAttribute("aria-current", "true");
        else dot.removeAttribute("aria-current");
      });
    };

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        photos[index]?.scrollIntoView({
          behavior: "smooth",
          block: "nearest",
          inline: "start",
        });
      });
    });

    const observer = new IntersectionObserver(
      (entries) => {
        const visiblePhoto = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (!visiblePhoto) return;

        const index = Number(visiblePhoto.target.getAttribute("data-index"));
        setActiveDot(index);
      },
      { root: gallery, threshold: [0.55, 0.75] },
    );

    photos.forEach((photo) => observer.observe(photo));
  })();
</script>

<style>
  .schedule__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.68fr);
    gap: clamp(42px, 7vw, 96px);
    align-items: start;
  }

  .schedule__panel {
    padding: clamp(24px, 4vw, 42px);
    background: var(--color-black);
    border-radius: var(--radius-card);
    color: var(--color-white);
  }

  h3 {
    margin-bottom: 30px;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 3rem);
    font-weight: 640;
    letter-spacing: var(--tracking-display);
    line-height: 0.98;
  }

  dl {
    display: grid;
  }

  .schedule__row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 20px;
    padding-block: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }

  .schedule__row:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  dt {
    font-weight: 750;
  }

  dd {
    margin: 0;
    color: rgba(255, 255, 255, 0.78);
    text-align: right;
  }

  .schedule__panel p {
    margin-top: 28px;
    color: rgba(255, 255, 255, 0.74);
    line-height: 1.75;
  }

  .schedule__gallery-wrap {
    position: relative;
    width: 100vw;
    margin-top: clamp(40px, 6vw, 76px);
    margin-left: calc(50% - 50vw);
  }

  .schedule__gallery {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 50vw;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
  }

  .schedule__gallery::-webkit-scrollbar {
    display: none;
  }

  .schedule__photo {
    margin: 0;
    overflow: hidden;
    background: var(--color-gray-100);
    scroll-snap-align: start;
  }

  .schedule__photo img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .schedule__dots {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 18px;
    display: flex;
    justify-content: center;
    gap: 9px;
  }

  .schedule__dot {
    display: block;
    flex: 0 0 11px;
    width: 11px;
    min-width: 11px;
    max-width: 11px;
    height: 11px;
    min-height: 11px;
    max-height: 11px;
    aspect-ratio: 1;
    padding: 0;
    appearance: none;
    -webkit-appearance: none;
    background: var(--color-white);
    border: 0;
    border-radius: 50%;
    opacity: 0.58;
    cursor: pointer;
    transition:
      opacity 180ms var(--ease-out),
      transform 180ms var(--ease-out);
  }

  .schedule__dot:hover,
  .schedule__dot:focus-visible,
  .schedule__dot.is-active {
    opacity: 1;
    transform: scale(1.18);
  }

  .schedule__dot:focus-visible {
    outline: 2px solid var(--color-white);
    outline-offset: 3px;
  }

  @media (max-width: 880px) {
    .schedule__inner {
      grid-template-columns: 1fr;
    }

    .schedule__gallery {
      grid-auto-columns: 82vw;
    }
  }

  @media (max-width: 520px) {
    .schedule__row {
      grid-template-columns: 1fr;
      gap: 6px;
    }

    dd {
      text-align: left;
    }

    .schedule__gallery {
      grid-auto-columns: 100%;
    }
  }
</style>
