---
import { contact } from "@data/contact";
import { navigation } from "@data/navigation";

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container-wide">
    <div>
      <p>© {year} JV DEV & DESIGN</p>
    </div>

    <address class="footer__contact">
      <span>{contact.location}</span>
      <a href={`mailto:${contact.email}`}>{contact.email}</a>
    </address>
  </div>
</footer>

<style>
  .footer {
    padding-block: 34px;
    color: var(--color-white);
    background: var(--color-black);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 32px;
    align-items: center;
  }

  .footer__brand {
    display: inline-flex;
    margin-bottom: 8px;
    font-family: var(--font-display);
    font-size: 1.32rem;
    font-weight: 720;
    letter-spacing: var(--tracking-display);
    line-height: 1;
    text-decoration: none;
  }

  p,
  .footer__contact {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .footer__nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    justify-content: center;
    list-style: none;
  }

  .footer__nav a,
  .footer__contact a {
    color: inherit;
    text-decoration: none;
  }

  .footer__nav a {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .footer__contact {
    display: grid;
    gap: 4px;
    justify-items: end;
  }

  @media (max-width: 880px) {
    .footer__inner {
      grid-template-columns: 1fr;
      justify-items: start;
    }

    .footer__nav ul {
      justify-content: flex-start;
    }

    .footer__contact {
      justify-items: start;
    }
  }
</style>
