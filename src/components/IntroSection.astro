---
import SectionHeading from "./SectionHeading.astro";
import motawaImage from "../assets/motawa.webp";
import shopImage from "../assets/shop.jpeg";
import waveImage from "../assets/wave.webp";
---

<section id="info-escuela" class="intro section">
  <div class="intro__page-heading" data-reveal>
    <p class="section-kicker">Santa Killa</p>
    <h1>Escuela de surf en El Palmar</h1>
  </div>

  <div class="container">
    <div class="intro__content">
      <div class="intro__copy">
        <SectionHeading
          eyebrow="Info escuela"
          title="Surf, mar y libertad. Eso es Santa Killa."
          intro=""
        />
        <div class="intro__body" data-reveal>
          <p>
            Desde las playas de El Palmar, Sergio y Juanlu llevan toda una vida
            dedicados al surf y ahora comparten esa pasión a través de una
            escuela pensada para todos los niveles. Nuestra misión es que
            disfrutes cada ola, aprendas de verdad y vivas la experiencia del
            surf desde dentro.
          </p>
          <p>Más que una escuela, somos una comunidad unida por el mar.</p>
          <a class="text-link" href="#contacto">Hablar con la escuela</a>
        </div>
      </div>

      <figure class="intro__illustration" data-reveal>
        <img
          src="/images/ilustr-black.png"
          alt=""
          width="920"
          height="731"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </div>
  </div>

  <div
    class="intro__carousel-wrap"
    aria-label="Ambiente de la escuela Santa Killa"
    data-reveal
  >
    <div class="intro__carousel" role="list" data-intro-carousel>
      <figure class="intro__slide" role="listitem" data-intro-slide data-index="0">
        <img
          src={motawaImage.src}
          alt="Instructor de surf preparando una clase en la playa de El Palmar"
          width={motawaImage.width}
          height={motawaImage.height}
          loading="lazy"
          decoding="async"
        />
      </figure>
      <figure class="intro__slide" role="listitem" data-intro-slide data-index="1">
        <img
          src={shopImage.src}
          alt="Tablas de surf alineadas sobre arena clara antes de una clase"
          width={shopImage.width}
          height={shopImage.height}
          loading="lazy"
          decoding="async"
        />
      </figure>
      <figure class="intro__slide" role="listitem" data-intro-slide data-index="2">
        <img
          src={waveImage.src}
          alt="Grupo pequeño entrando al agua para una clase de surf en Cádiz"
          width={waveImage.width}
          height={waveImage.height}
          loading="lazy"
          decoding="async"
        />
      </figure>
    </div>
    <div class="intro__dots" aria-label="Seleccionar foto del carrusel">
      {
        [0, 1, 2].map((index) => (
          <button
            class:list={["intro__dot", { "is-active": index === 0 }]}
            type="button"
            aria-label={`Ver foto ${index + 1} de 3`}
            aria-current={index === 0 ? "true" : undefined}
            data-intro-dot
          />
        ))
      }
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const carousel = document.querySelector("[data-intro-carousel]");
    if (!(carousel instanceof HTMLElement)) return;

    const slides = [...carousel.querySelectorAll("[data-intro-slide]")];
    const dots = [...document.querySelectorAll("[data-intro-dot]")];

    const setActiveDot = (activeIndex) => {
      dots.forEach((dot, index) => {
        const isActive = index === activeIndex;
        dot.classList.toggle("is-active", isActive);
        if (isActive) dot.setAttribute("aria-current", "true");
        else dot.removeAttribute("aria-current");
      });
    };

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        slides[index]?.scrollIntoView({
          behavior: "smooth",
          block: "nearest",
          inline: "start",
        });
      });
    });

    const observer = new IntersectionObserver(
      (entries) => {
        const visibleSlide = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (!visibleSlide) return;
        setActiveDot(Number(visibleSlide.target.getAttribute("data-index")));
      },
      { root: carousel, threshold: [0.55, 0.75] },
    );

    slides.forEach((slide) => observer.observe(slide));
  })();
</script>

<style>
  .intro__content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.56fr);
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
  }

  .intro__copy {
    width: 100%;
    max-width: 760px;
  }

  .intro__illustration {
    margin: 0;
    justify-self: end;
    width: min(100%, 430px);
  }

  .intro__illustration img {
    display: block;
    width: 100%;
    height: auto;
  }

  .intro__page-heading {
    display: grid;
    justify-items: center;
    width: 100%;
    margin: 0 auto 10rem;
    padding-inline: 20px;
    text-align: center;
  }

  .intro__page-heading .section-kicker {
    margin-inline: auto;
  }

  .intro__page-heading h1 {
    width: min(100%, 980px);
    margin-inline: auto;
    font-family: var(--font-display);
    font-size: clamp(3.4rem, 8.8vw, 7.4rem);
    font-weight: 640;
    letter-spacing: var(--tracking-display);
    line-height: 0.9;
    text-align: center;
    text-wrap: balance;
  }

  .intro__body {
    display: grid;
    gap: 20px;
    max-width: 630px;
    margin-top: 32px;
    color: var(--color-gray-600);
    font-size: 1.02rem;
    line-height: 1.85;
  }

  .intro__body .text-link {
    margin-top: 10px;
    color: var(--color-black);
  }

  .intro__carousel-wrap {
    position: relative;
    width: 100vw;
    margin-top: clamp(34px, 5vw, 56px);
    margin-left: calc(50% - 50vw);
  }

  .intro__carousel {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(320px, 42vw);
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
  }

  .intro__carousel::-webkit-scrollbar {
    display: none;
  }

  .intro__slide {
    margin: 0;
    overflow: hidden;
    background: var(--color-gray-100);
    scroll-snap-align: start;
  }

  .intro__slide img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .intro__dots {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 18px;
    display: flex;
    justify-content: center;
    gap: 9px;
  }

  .intro__dot {
    display: block;
    flex: 0 0 11px;
    width: 11px;
    min-width: 11px;
    max-width: 11px;
    height: 11px;
    min-height: 11px;
    max-height: 11px;
    aspect-ratio: 1;
    padding: 0;
    appearance: none;
    -webkit-appearance: none;
    background: var(--color-white);
    border: 0;
    border-radius: 50%;
    opacity: 0.58;
    cursor: pointer;
    transition:
      opacity 180ms var(--ease-out),
      transform 180ms var(--ease-out);
  }

  .intro__dot:hover,
  .intro__dot:focus-visible,
  .intro__dot.is-active {
    opacity: 1;
    transform: scale(1.18);
  }

  .intro__dot:focus-visible {
    outline: 2px solid var(--color-white);
    outline-offset: 3px;
  }

  @media (max-width: 1024px) {
    .intro__page-heading {
      margin-bottom: 7rem;
      margin-inline: auto;
      padding-inline: 0;
    }
  }

  @media (max-width: 900px) {
    .intro__content {
      grid-template-columns: 1fr;
    }

    .intro__illustration {
      justify-self: center;
      width: min(100%, 340px);
    }
  }

  @media (max-width: 880px) {
    .intro__carousel {
      grid-auto-columns: 82vw;
    }
  }

  @media (max-width: 560px) {
    .intro__page-heading {
      margin-bottom: 5.5rem;
    }

    .intro__page-heading h1 {
      font-size: clamp(3.2rem, 15vw, 5.4rem);
    }

    .intro__carousel {
      grid-auto-columns: 100%;
    }
  }
</style>
