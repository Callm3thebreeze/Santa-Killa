---
import "@styles/global.css";

type JsonLd = Record<string, unknown> | Record<string, unknown>[];

type Props = {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: JsonLd;
};

const {
  title,
  description,
  canonical,
  ogImage = "/images/hero-poster.svg",
  jsonLd = [],
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://www.santakilla.com");
const canonicalUrl =
  canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(ogImage, siteUrl).toString();
const sitemapUrl = new URL("/sitemap.xml", siteUrl).toString();
const jsonLdMarkup = JSON.stringify(jsonLd);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow, max-image-preview:large" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" href={canonicalUrl} hreflang="es-ES" />
    <link rel="alternate" href={canonicalUrl} hreflang="x-default" />
    <link rel="sitemap" href={sitemapUrl} type="application/xml" />
    <link rel="icon" href="/images/white-logo.png" type="image/png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=SUSE:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Santa Killa" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta
      property="og:image:alt"
      content="Santa Killa, escuela de surf en El Palmar"
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <script type="application/ld+json" set:html={jsonLdMarkup} is:inline />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <slot />
    <script>
      import "../scripts/site";
    </script>
  </body>
</html>
